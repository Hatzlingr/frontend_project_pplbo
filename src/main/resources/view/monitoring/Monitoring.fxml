<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="monitoring-page" stylesheets="@monitoring-style.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.features.monitoring.MonitoringController">
    <top>
        <VBox spacing="12.0" styleClass="monitoring-top-wrapper">
            <children>
                <Label styleClass="monitoring-title" text="Monitoring PC" />
                <HBox spacing="12.0" styleClass="monitoring-summary-row">
                    <children>
                        <VBox spacing="6.0" styleClass="summary-card">
                            <children>
                                <Label styleClass="summary-title" text="PC Reguler" />
                                <Label fx:id="lblRegulerActive" styleClass="summary-metric" text="Aktif: 0" />
                                <Label fx:id="lblRegulerAvailable" styleClass="summary-submetric" text="Available: 0" />
                            </children>
                            <padding>
                                <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
                            </padding>
                        </VBox>
                        <VBox spacing="6.0" styleClass="summary-card">
                            <children>
                                <Label styleClass="summary-title" text="PC VIP" />
                                <Label fx:id="lblVipActive" styleClass="summary-metric" text="Aktif: 0" />
                                <Label fx:id="lblVipAvailable" styleClass="summary-submetric" text="Available: 0" />
                            </children>
                            <padding>
                                <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
                            </padding>
                        </VBox>
                    </children>
                    <padding>
                        <Insets left="18.0" right="18.0" />
                    </padding>
                </HBox>
            </children>
        </VBox>
    </top>
    <center>
        <ScrollPane fitToHeight="true" fitToWidth="true" pannable="true" styleClass="monitoring-scrollpane">
            <content>
                <VBox spacing="14.0" styleClass="monitoring-sections">
                    <children>
                        <Label styleClass="section-title" text="PC Reguler" />
                        <FlowPane fx:id="regulerContainer" hgap="10.0" styleClass="monitoring-grid" vgap="10.0">
                            <padding>
                                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                            </padding>
                        </FlowPane>
                        <Separator />
                        <Label styleClass="section-title" text="PC VIP" />
                        <FlowPane fx:id="vipContainer" hgap="10.0" styleClass="monitoring-grid" vgap="10.0">
                            <padding>
                                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                            </padding>
                        </FlowPane>
                    </children>
                    <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                    </padding>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
