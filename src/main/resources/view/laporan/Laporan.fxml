<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane styleClass="page-root"
            stylesheets="@laporan-style.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1">
    <top>
        <VBox spacing="14.0" styleClass="page-header">
            <VBox spacing="4.0">
                <Label styleClass="page-title" text="Laporan" />
                <Label styleClass="page-subtitle" text="Summary pendapatan F&amp;B, billing, dan topup member." />
            </VBox>
            <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="toolbar">
                <DatePicker fx:id="reportStartDatePicker" prefWidth="150.0" styleClass="form-input" />
                <DatePicker fx:id="reportEndDatePicker" prefWidth="150.0" styleClass="form-input" />
                <Button fx:id="applyReportFilterButton" styleClass="primary-button" text="Terapkan" />
                <Button fx:id="exportReportButton" styleClass="secondary-button" text="Export" />
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="content-scroll">
            <VBox spacing="20.0" styleClass="content-wrapper">
                <GridPane hgap="16.0" vgap="16.0">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="25" />
                        <ColumnConstraints percentWidth="25" />
                        <ColumnConstraints percentWidth="25" />
                        <ColumnConstraints percentWidth="25" />
                    </columnConstraints>
                    <VBox styleClass="stat-card" spacing="8.0" GridPane.columnIndex="0">
                        <Label styleClass="stat-title" text="TOTAL REVENUE" />
                        <Label fx:id="totalRevenueLabel" styleClass="stat-value stat-money" text="Rp0" />
                    </VBox>
                    <VBox styleClass="stat-card" spacing="8.0" GridPane.columnIndex="1">
                        <Label styleClass="stat-title" text="F&amp;B REVENUE" />
                        <Label fx:id="foodRevenueLabel" styleClass="stat-value stat-money" text="Rp0" />
                    </VBox>
                    <VBox styleClass="stat-card" spacing="8.0" GridPane.columnIndex="2">
                        <Label styleClass="stat-title" text="BILLING REVENUE" />
                        <Label fx:id="billingRevenueLabel" styleClass="stat-value stat-money" text="Rp0" />
                    </VBox>
                    <VBox styleClass="stat-card" spacing="8.0" GridPane.columnIndex="3">
                        <Label styleClass="stat-title" text="TOPUP MEMBER" />
                        <Label fx:id="memberTopupRevenueLabel" styleClass="stat-value stat-money" text="Rp0" />
                    </VBox>
                </GridPane>

                <HBox spacing="16.0">
                    <VBox spacing="12.0" styleClass="card" HBox.hgrow="ALWAYS">
                        <padding><Insets top="18" right="18" bottom="18" left="18" /></padding>
                        <Label styleClass="section-title" text="Breakdown Pendapatan" />
                        <VBox fx:id="revenueBreakdownContainer" spacing="10.0">
                            <Label styleClass="section-subtitle" text="Placeholder chart/list. Controller dapat mengisi chart JavaFX atau card breakdown." />
                        </VBox>
                    </VBox>
                    <VBox spacing="12.0" styleClass="card" prefWidth="360.0">
                        <padding><Insets top="18" right="18" bottom="18" left="18" /></padding>
                        <Label styleClass="section-title" text="Insight" />
                        <Label styleClass="row-subtitle" wrapText="true" text="Halaman ini disiapkan sebagai UI laporan dummy. Backend dapat mengisi data summary setelah service tersedia." />
                    </VBox>
                </HBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
