<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="sidebarRoot" fillWidth="true" prefWidth="272.0" spacing="18.0" styleClass="sidebar" stylesheets="@sidebar-style.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1">

    <padding>
        <Insets bottom="24.0" left="16.0" right="16.0" top="24.0" />
    </padding>

    <children>
        <VBox spacing="4.0" styleClass="sidebar-header">
            <Label styleClass="sidebar-logo" text="DEA.JAYA.NET" />
            <Label styleClass="sidebar-subtitle" text="Admin Console" />
        </VBox>

        <Separator styleClass="sidebar-separator" />

        <VBox spacing="6.0">
            <Label styleClass="sidebar-title" text="OPERASIONAL" />
            <Button fx:id="dashboardButton" maxWidth="Infinity" styleClass="menu-btn" text="Dashboard" />
            <Button fx:id="monitoringButton" maxWidth="Infinity" styleClass="menu-btn" text="Monitoring Sesi" />
            <Button fx:id="topupMemberButton" maxWidth="Infinity" styleClass="menu-btn" text="Topup Member" />
            <Button fx:id="pesananButton" maxWidth="Infinity" styleClass="menu-btn" text="Pusat Pesanan" />
        </VBox>

        <VBox spacing="6.0">
            <Label styleClass="sidebar-title" text="MANAJEMEN" />
            <Button fx:id="userButton" maxWidth="Infinity" styleClass="menu-btn" text="User" />
            <Button fx:id="komputerButton" maxWidth="Infinity" styleClass="menu-btn" text="Komputer" />
            <Button fx:id="foodMenuButton" maxWidth="Infinity" styleClass="menu-btn" text="Menu F&amp;B" />
            <Button fx:id="billingPackageButton" maxWidth="Infinity" styleClass="menu-btn" text="Paket Billing" />
        </VBox>

        <VBox spacing="6.0">
            <Label styleClass="sidebar-title" text="RIWAYAT &amp; LAPORAN" />
            <Button fx:id="riwayatTransaksiButton" maxWidth="Infinity" styleClass="menu-btn" text="Riwayat Transaksi" />
            <Button fx:id="laporanButton" maxWidth="Infinity" styleClass="menu-btn" text="Laporan" />
        </VBox>

        <Region VBox.vgrow="ALWAYS" />

        <VBox spacing="12.0">
            <Button fx:id="transactionDetailButton" styleClass="secondary-button" text="Logout" />
        </VBox>
    </children>
</VBox>
