<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.VBox?>

<VBox fillWidth="true" prefWidth="260.0" spacing="6.0" styleClass="sidebar" stylesheets="@sidebar-style.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.features.sidebar.SidebarController">

    <padding>
        <Insets bottom="24.0" left="14.0" right="14.0" top="24.0" />
    </padding>

    <children>
      <VBox alignment="CENTER_LEFT" prefHeight="64.0" prefWidth="100.0" styleClass="sidebar-header">
         <children>
            <Label styleClass="sidebar-logo" text="DEA.JAYA.NET" />
            <Label layoutX="10.0" layoutY="10.0" styleClass="sidebar-subtitle" text="Admin" />
         </children>
      </VBox>
      <Separator prefWidth="200.0" />
        <Label styleClass="sidebar-title" text="Operasional" />
        <Button fx:id="dashboardButton" maxWidth="Infinity" styleClass="menu-btn" text="Dashboard" />
        <Button fx:id="monitoringButton" maxWidth="Infinity" styleClass="menu-btn" text="Monitoring Sesi" />
        <Button fx:id="pesananButton" maxWidth="Infinity" styleClass="menu-btn" text="Pusat Pesanan" />
      <Button fx:id="antrianButton" layoutX="24.0" layoutY="189.0" maxWidth="Infinity" styleClass="menu-btn" text="Antrian Verifikasi" />
      <Label styleClass="sidebar-title" text="Manajemen" />
      <Button fx:id="userButton" layoutX="24.0" layoutY="111.0" maxWidth="Infinity" styleClass="menu-btn" text="User" />
        <Button fx:id="komputerButton" maxWidth="Infinity" styleClass="menu-btn" text="Komputer" />
        <Button fx:id="hargaButton" maxWidth="Infinity" styleClass="menu-btn" text="Menu &amp; Harga" />
      <Label styleClass="sidebar-title" text="Riwayat &amp; Laporan" />
        <Button fx:id="riwayatTransaksiButton" maxWidth="Infinity" styleClass="menu-btn" text="Riwayat Transaksi" />
        <Button fx:id="laporanButton" maxWidth="Infinity" styleClass="menu-btn" text="Laporan" />
      <Label styleClass="sidebar-title" text="Sistem" />
        <Button fx:id="settingButton" maxWidth="Infinity" styleClass="menu-btn" text="Pengaturan" />
    </children>
</VBox>
