<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>

<HBox alignment="CENTER_LEFT" minHeight="50.0" styleClass="item-row" stylesheets="@pesanan-style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
   <padding>
      <Insets left="20.0" right="20.0" />
   </padding>
   <children>
      
      <!-- Kolom PC & Icon -->
      <HBox alignment="CENTER_LEFT" prefWidth="120.0" spacing="10.0">
         <children>
            <Region prefHeight="20.0" prefWidth="20.0" styleClass="icon-pc" />
            <Label styleClass="item-text-bold" text="PC-05" />
         </children>
      </HBox>
      
      <!-- Kolom Menu -->
      <Label prefWidth="250.0" styleClass="item-text-bold" text="Nasi Goreng" />
      
      <!-- Kolom Jumlah -->
      <Label prefWidth="100.0" styleClass="item-text-bold" text="2" />
      
      <!-- Kolom Waktu -->
      <Label prefWidth="150.0" styleClass="item-text-bold" text="12:12:0" />
      
      <!-- Kolom Status (Ubah class via Java nanti: status-proses / status-selesai / status-batal) -->
      <Label prefWidth="120.0" styleClass="status-proses" text="Proses" />
      
      <!-- Kolom Aksi -->
      <HBox alignment="CENTER_LEFT" spacing="10.0">
         <children>
            <Button mnemonicParsing="false" styleClass="btn-outline-yellow" text="Edit" />
            <Button mnemonicParsing="false" styleClass="btn-outline-red" text="Hapus" />
         </children>
      </HBox>
      
   </children>
</HBox>