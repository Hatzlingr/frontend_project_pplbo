<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<HBox fx:id="orderCardRoot" alignment="CENTER_LEFT" spacing="16.0" styleClass="order-card card" stylesheets="@pesanan-style.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets bottom="16" left="18" right="18" top="16" />
    </padding>
    <children>
        <VBox prefWidth="150.0" spacing="5.0">
            <Label fx:id="orderNumberLabel" styleClass="row-title" text="#ORD-001" />
            <Label fx:id="orderSourceLabel" styleClass="row-subtitle" text="PC-05 / Guest" />
            <Label fx:id="orderTimeLabel" styleClass="row-subtitle mono-text" text="12:30" />
        </VBox>

        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
            <Label styleClass="form-label" text="ITEM PESANAN" />
            <Label fx:id="orderItemsLabel" styleClass="order-items" text="Indomie Goreng x2&#10;Es Teh Manis x1" wrapText="true" />
        </VBox>

        <VBox alignment="CENTER_RIGHT" prefWidth="160.0" spacing="6.0">
            <Label fx:id="orderTotalLabel" styleClass="amount-text" text="Rp25.000" />
            <Label fx:id="orderStatusBadge" styleClass="badge badge-warning" text="MENUNGGU" />
        </VBox>

        <VBox alignment="CENTER_RIGHT" prefWidth="170.0" spacing="8.0">
            <Button fx:id="nextKitchenStatusButton" maxWidth="Infinity" styleClass="primary-button" text="Proses" />
            <Button fx:id="viewOrderDetailButton" maxWidth="Infinity" styleClass="secondary-button" text="Batalkan" />
        </VBox>
    </children>
</HBox>
