<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane styleClass="page-root"
            stylesheets="@manajemen-user-style.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1">
    <top>
        <VBox spacing="6.0" styleClass="page-header">
            <Label styleClass="page-title" text="Manajemen User" />
            <Label styleClass="page-subtitle" text="Kelola admin, kasir, dan member. Member memiliki remaining time." />
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="content-scroll">
            <VBox spacing="18.0" styleClass="content-wrapper" prefWidth="800">
                <VBox spacing="14.0" styleClass="card">
                    <padding><Insets top="18" right="18" bottom="18" left="18" /></padding>
                    <HBox alignment="CENTER_LEFT">
                        <VBox HBox.hgrow="ALWAYS">
                            <Label fx:id="userFormTitleLabel" styleClass="section-title" text="Tambah User" />
                            <Label fx:id="userFormSubtitleLabel" styleClass="section-subtitle" text="Isi data lalu simpan." />
                        </VBox>
                        <Label fx:id="userEditModeBadge" styleClass="badge badge-info" text="CREATE" />
                    </HBox>
                    <VBox spacing="8.0">
                        <Label styleClass="form-label" text="Nama" />
                        <TextField fx:id="userNameField" promptText="Nama lengkap" styleClass="form-input" />
                    </VBox>
                    <VBox spacing="8.0">
                        <Label styleClass="form-label" text="Username" />
                        <TextField fx:id="usernameField" promptText="username" styleClass="form-input" />
                    </VBox>
                    <VBox spacing="8.0">
                        <Label styleClass="form-label" text="Role" />
                        <ComboBox fx:id="userRoleCombo" maxWidth="Infinity" promptText="Admin / Kasir / Member" styleClass="form-combo" />
                    </VBox>
                    <VBox spacing="8.0">
                        <Label styleClass="form-label" text="Remaining Time Member" />
                        <TextField fx:id="remainingTimeField" promptText="0 menit" styleClass="form-input" />
                    </VBox>
                    <HBox spacing="8.0">
                        <Button fx:id="saveUserButton" maxWidth="Infinity" HBox.hgrow="ALWAYS" styleClass="primary-button" text="Simpan" />
                        <Button fx:id="cancelEditUserButton" styleClass="secondary-button" text="Batal" visible="false" managed="false" />
                    </HBox>
                </VBox>

                <VBox spacing="14.0" HBox.hgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="toolbar">
                        <TextField fx:id="searchUserField" promptText="Cari nama / username..." styleClass="search-field" HBox.hgrow="ALWAYS" />
                        <ComboBox fx:id="roleFilterCombo" prefWidth="160.0" promptText="Semua Role" styleClass="form-combo" />
                    </HBox>
                    <VBox fx:id="userRowContainer" spacing="12.0" />
                    <VBox fx:id="emptyUserState" alignment="CENTER" spacing="8.0" styleClass="empty-state" visible="false" managed="false">
                        <Label styleClass="empty-title" text="Belum ada user" />
                        <Label styleClass="empty-subtitle" text="Tambahkan user pertama lewat form di kiri." />
                    </VBox>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
