<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefWidth="400.0" spacing="20.0" styleClass="popup-container" stylesheets="@manajemen-pc-style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <!-- Judul Pop-up -->
      <Label styleClass="popup-title" text="Edit Data Komputer" />
      
      <!-- Area Form -->
      <VBox spacing="15.0">
         <children>
            
            <!-- Input Nomor PC -->
            <VBox spacing="5.0">
               <children>
                  <Label styleClass="form-label" text="Nomor PC" />
                  <TextField promptText="Contoh: PC-01" styleClass="form-input" />
               </children>
            </VBox>

            <!-- tipe Spesifikasi -->
            <VBox spacing="5.0">
               <children>
                  <Label styleClass="form-label" text="Tipe Spesifikasi" />
                  <TextField promptText="Masukkan tipe spesifikasi" styleClass="form-input" />
               </children>
            </VBox>
            
         </children>
      </VBox>

      <!-- Area Tombol -->
      <HBox alignment="CENTER_RIGHT" spacing="15.0">
         <children>
            <Button mnemonicParsing="false" styleClass="btn-secondary" text="Batal" />
            <Button mnemonicParsing="false" styleClass="btn-primary" text="Simpan Data" />
         </children>
      </HBox>
   </children>
</VBox>