<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="page-root" stylesheets="@manajemen-paket-billing-style.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1">
    <top>
        <VBox spacing="6.0" styleClass="page-header">
            <Label styleClass="page-title" text="Paket Billing" />
            <Label styleClass="page-subtitle" text="Kelola paket durasi dan harga untuk topup member atau tambah waktu session." />
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="content-scroll">
            <VBox spacing="18.0" styleClass="content-wrapper" prefWidth="800.0">
                <VBox spacing="14.0" styleClass="card">
                    <padding><Insets bottom="18" left="18" right="18" top="18" /></padding>
                    <HBox alignment="CENTER_LEFT">
                        <VBox HBox.hgrow="ALWAYS">
                            <Label fx:id="packageFormTitleLabel" styleClass="section-title" text="Tambah Paket" />
                            <Label fx:id="packageFormSubtitleLabel" styleClass="section-subtitle" text="Billing package action-based." />
                        </VBox>
                        <Label fx:id="packageEditModeBadge" styleClass="badge badge-info" text="CREATE" />
                    </HBox>
                    <VBox spacing="6.0">
                        <Label styleClass="form-label" text="Nama Paket" />
                        <TextField fx:id="packageNameField" promptText="Paket 1 Jam" styleClass="form-input" />
                    </VBox>
                    <HBox spacing="10.0">
                        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                            <Label styleClass="form-label" text="Durasi (menit)" />
                            <TextField fx:id="packageDurationField" promptText="60" styleClass="form-input" />
                        </VBox>
                        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                            <Label styleClass="form-label" text="Harga" />
                            <TextField fx:id="packagePriceField" promptText="5000" styleClass="form-input" />
                        </VBox>
                    </HBox>
                    <VBox spacing="6.0">
                        <Label styleClass="form-label" text="Tipe Paket" />
                        <ComboBox fx:id="packageTypeCombo" maxWidth="Infinity" promptText="Regular / VIP" styleClass="form-combo" />
                    </VBox>
                    <VBox spacing="6.0">
                        <Label styleClass="form-label" text="Status" />
                        <ComboBox fx:id="packageActiveCombo" maxWidth="Infinity" promptText="Aktif / Nonaktif" styleClass="form-combo" />
                    </VBox>
                    <HBox spacing="8.0">
                        <Button fx:id="savePackageButton" maxWidth="Infinity" styleClass="primary-button" text="Simpan" HBox.hgrow="ALWAYS" />
                        <Button fx:id="cancelEditPackageButton" managed="false" styleClass="secondary-button" text="Batal" visible="false" />
                    </HBox>
                </VBox>

                <VBox spacing="14.0" HBox.hgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="toolbar">
                        <TextField fx:id="searchPackageField" promptText="Cari nama paket..." styleClass="search-field" HBox.hgrow="ALWAYS" />
                        <ComboBox fx:id="packageTypeFilterCombo" prefWidth="160.0" promptText="Semua Tipe" styleClass="form-combo" />
                        <ComboBox fx:id="packageStatusFilterCombo" prefWidth="150.0" promptText="Semua Status" styleClass="form-combo" />
                    </HBox>
                    <VBox fx:id="packageRowContainer" spacing="12.0" />
                    <VBox fx:id="emptyPackageState" alignment="CENTER" managed="false" spacing="8.0" styleClass="empty-state" visible="false">
                        <Label styleClass="empty-title" text="Belum ada paket billing" />
                        <Label styleClass="empty-subtitle" text="Tambahkan paket durasi dari form di kiri." />
                    </VBox>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
