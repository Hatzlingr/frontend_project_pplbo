<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox alignment="CENTER_LEFT"
      spacing="16.0"
      styleClass="food-row card-flat"
      stylesheets="@manajemen-food-style.css"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1">
    <padding><Insets top="14" right="16" bottom="14" left="16" /></padding>
    <children>
        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="8.0">
                <Label fx:id="foodNameLabel" styleClass="row-title" text="Indomie Goreng" />
                <Label fx:id="foodCategoryBadge" styleClass="badge badge-info" text="Makanan" />
                <Label fx:id="foodStatusBadge" styleClass="badge badge-success" text="Tersedia" />
            </HBox>
            <Label fx:id="foodPriceLabel" styleClass="amount-text" text="Rp10.000" />
        </VBox>
        <VBox alignment="CENTER" spacing="6.0" prefWidth="175.0">
            <Label styleClass="form-label" text="Edit Stok" />
            <HBox alignment="CENTER" spacing="7.0">
                <Button fx:id="decreaseStockButton" styleClass="stock-button" text="−" />
                <TextField fx:id="stockField" alignment="CENTER" prefWidth="62.0" styleClass="form-input stock-field" text="18" />
                <Button fx:id="increaseStockButton" styleClass="stock-button" text="+" />
            </HBox>
        </VBox>
        <VBox alignment="CENTER_RIGHT" spacing="8.0" prefWidth="210.0">
            <HBox spacing="8.0">
                <Button fx:id="saveStockButton" styleClass="primary-button" text="Simpan Stok" />
                <Button fx:id="editFoodButton" styleClass="secondary-button" text="Edit" />
            </HBox>
            <HBox spacing="8.0">
                <Button fx:id="toggleFoodActiveButton" styleClass="warning-button" text="Nonaktifkan" />
                <Button fx:id="deleteFoodButton" styleClass="danger-button" text="Delete" />
            </HBox>
        </VBox>
    </children>
</HBox>
